{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rosenadvertising.github.io/brand-guide-schema/v0.1/schema.json",
  "title": "Brand Guide",
  "description": "Machine-readable brand identity context for AI agents and design tooling.",
  "type": "object",
  "required": ["brand", "website", "category", "last_updated", "positioning", "markets", "colors", "typography", "voice"],
  "additionalProperties": false,
  "properties": {
    "brand": {
      "type": "string",
      "description": "Full brand name"
    },
    "website": {
      "type": "string",
      "description": "Primary domain (no protocol)",
      "pattern": "^(?!https?://).+"
    },
    "category": {
      "type": "string",
      "description": "Industry and subcategory descriptor, e.g. 'Legal — Family Law' or 'SaaS — Project Management'"
    },
    "last_updated": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date the guide was last reviewed"
    },
    "version": {
      "type": "string",
      "description": "Brand guide version (semver). Increment when the guide is meaningfully updated.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "legal_name": {
      "type": "string",
      "description": "Registered legal entity name, if different from brand name"
    },
    "locale": {
      "type": "string",
      "description": "Primary language/region code, e.g. 'en-US', 'th-TH'",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
    },
    "taglines": {
      "type": "array",
      "items": { "type": "string" },
      "description": "One or more brand taglines, in priority order"
    },
    "positioning": {
      "type": "object",
      "description": "Brand positioning — structured components and final statement",
      "required": ["statement"],
      "properties": {
        "statement": { "type": "string", "description": "Final one or two sentence positioning statement" },
        "for": { "type": "string", "description": "Target audience (e.g. 'small law firms in the Southeast')" },
        "category": { "type": "string", "description": "Category the brand competes in" },
        "benefit": { "type": "string", "description": "Primary benefit or value delivered" }
      },
      "additionalProperties": false
    },
    "differentiation": {
      "type": "string",
      "description": "One sentence: what this brand explicitly is not, or how it differs from alternatives"
    },
    "markets": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Geographic or demographic markets served"
    },
    "audience": {
      "type": "object",
      "description": "Who the brand is speaking to — for copy and content agents",
      "required": ["primary"],
      "properties": {
        "primary": { "type": "string", "description": "One sentence: who the ideal customer is" },
        "pain_points": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What the audience is trying to solve or escape"
        },
        "motivations": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What the audience is trying to achieve or become"
        }
      },
      "additionalProperties": false
    },
    "services": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Products or services offered"
    },
    "restrictions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Off-limits language, claims, or topics. Essential for regulated industries."
    },
    "imagery_style": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Art direction for photos and visuals (e.g. 'real people, candid', 'clean studio, white background')"
    },
    "colors": {
      "type": "object",
      "description": "Named color roles with hex values and usage guidance. primary and background are required.",
      "required": ["primary", "background"],
      "properties": {
        "primary": {
          "type": "object",
          "required": ["hex"],
          "properties": {
            "hex": { "type": "string", "pattern": "^#([0-9A-Fa-f]{3,4}|[0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$" },
            "usage": { "type": "string" }
          },
          "additionalProperties": false
        },
        "background": {
          "type": "object",
          "required": ["hex"],
          "properties": {
            "hex": { "type": "string", "pattern": "^#([0-9A-Fa-f]{3,4}|[0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$" },
            "usage": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": {
        "type": "object",
        "required": ["hex"],
        "properties": {
          "hex": {
            "type": "string",
            "pattern": "^#([0-9A-Fa-f]{3,4}|[0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$",
            "description": "Hex color value"
          },
          "usage": {
            "type": "string",
            "description": "Where and how this color is used"
          }
        },
        "additionalProperties": false
      }
    },
    "accessible_pairs": {
      "type": "array",
      "description": "Approved accessible color combinations (references color role names)",
      "items": {
        "type": "object",
        "required": ["text", "bg"],
        "properties": {
          "text": { "type": "string", "description": "Color role name for text" },
          "bg": { "type": "string", "description": "Color role name for background" }
        },
        "additionalProperties": false
      }
    },
    "color_mode": {
      "type": "string",
      "enum": ["light", "dark"],
      "description": "Default rendering mode when relevant"
    },
    "typography": {
      "type": "object",
      "description": "Named type roles (headings, body, display, etc.) with CSS font stack and optional type tokens",
      "additionalProperties": {
        "type": "object",
        "required": ["stack"],
        "properties": {
          "stack": { "type": "string", "description": "CSS font stack" },
          "weight": { "type": "integer", "description": "Font weight, e.g. 400, 700" },
          "size": { "type": "string", "description": "Base font size, e.g. '1rem', '16px'" },
          "line_height": { "type": "string", "description": "Line height, e.g. '1.5', '24px'" }
        },
        "additionalProperties": false
      }
    },
    "logo": {
      "type": "object",
      "description": "Logo variants and descriptions",
      "required": ["description", "has_icon_variant"],
      "properties": {
        "description": { "type": "string" },
        "logo_style": {
          "type": "string",
          "enum": ["wordmark", "lettermark", "pictorial", "abstract", "combination"],
          "description": "Structural type of the logo mark"
        },
        "has_icon_variant": { "type": "boolean" },
        "color": { "type": "string", "description": "Filename of full-color logo asset" },
        "white": { "type": "string", "description": "Filename of white/reversed logo asset" },
        "monogram": { "type": "string", "description": "Monogram character(s) used in compact contexts" },
        "wordmark": { "type": "string", "description": "Brand name as it appears in the wordmark (text)" },
        "icon_file": { "type": "string", "description": "Filename of standalone icon/mark asset" },
        "wordmark_file": { "type": "string", "description": "Filename of wordmark-only logo asset" }
      },
      "additionalProperties": false
    },
    "social": {
      "type": "object",
      "description": "Social handles or profile URLs, keyed by platform",
      "additionalProperties": { "type": "string" }
    },
    "voice": {
      "type": "object",
      "required": ["tone", "avoid"],
      "description": "Brand voice guidance for copy and content",
      "properties": {
        "tone": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Adjectives describing the brand's communication style"
        },
        "avoid": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Tones or styles that are off-brand"
        },
        "examples": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Sample on-brand sentences that demonstrate the voice in practice"
        }
      },
      "additionalProperties": false
    }
  }
}
